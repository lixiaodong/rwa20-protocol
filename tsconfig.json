{
  "compilerOptions": {
    "target":          "ES2020",
    "module":          "commonjs",
    "esModuleInterop": true,
    "strict":          true,
    "outDir":          "./dist",
    "declaration":     true,
    "resolveJsonModule": true,
    "skipLibCheck":    true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["scripts", "test", "hardhat.config.ts"],
  "exclude": ["node_modules", "dist", "frontend"]
}
